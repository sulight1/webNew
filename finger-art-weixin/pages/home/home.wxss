.home-hero {
  position: relative;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
  background: linear-gradient(135deg, #fff5fb 0%, #f3f0ff 55%, #fff 100%);
  border: 1rpx solid rgba(235, 47, 150, 0.1);
  box-shadow: 0 12rpx 40rpx rgba(235, 47, 150, 0.1);
}

.home-hero-mesh {
  position: absolute;
  inset: 0;
  overflow: hidden;
  pointer-events: none;
}

.mesh-blob {
  position: absolute;
  border-radius: 50%;
  opacity: 0.55;
}

.mesh-pink {
  width: 280rpx;
  height: 280rpx;
  background: #fff0f6;
  top: -80rpx;
  right: -40rpx;
}

.mesh-purple {
  width: 220rpx;
  height: 220rpx;
  background: #f9f0ff;
  bottom: -60rpx;
  left: -40rpx;
}

.home-hero-body {
  position: relative;
  padding: 40rpx 32rpx 32rpx;
}

.home-eyebrow {
  display: block;
  font-size: 20rpx;
  font-weight: 700;
  letter-spacing: 6rpx;
  color: #eb2f96;
  margin-bottom: 12rpx;
}

.home-title {
  font-size: 52rpx;
  font-weight: 800;
  color: #1a1a1a;
  line-height: 1.2;
}

.home-sub {
  display: block;
  color: #8c8c8c;
  font-size: 26rpx;
  margin: 16rpx 0 28rpx;
  line-height: 1.5;
}

.hero-stats {
  justify-content: space-around;
  background: rgba(255, 255, 255, 0.75);
  border-radius: 16rpx;
  padding: 24rpx 16rpx;
  margin-bottom: 28rpx;
  border: 1rpx solid rgba(235, 47, 150, 0.08);
}

.stat-item {
  text-align: center;
  flex: 1;
}

.stat-divider {
  width: 1rpx;
  height: 48rpx;
  background: rgba(235, 47, 150, 0.15);
}

.stat-num {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  background: linear-gradient(135deg, #eb2f96, #722ed1);
  -webkit-background-clip: text;
  color: transparent;
}

.stat-label {
  font-size: 22rpx;
  color: #8c8c8c;
  margin-top: 4rpx;
}

.hero-actions {
  gap: 20rpx;
}

.hero-actions button {
  flex: 1;
}

.btn-glass {
  background: rgba(255, 255, 255, 0.85) !important;
  backdrop-filter: blur(8px);
}

.gacha-banner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 24rpx 0 8rpx;
  padding: 24rpx 28rpx;
  border-radius: 20rpx;
  background: linear-gradient(135deg, #fff0f6 0%, #f9f0ff 100%);
  border: 1rpx solid rgba(235, 47, 150, 0.12);
  box-shadow: 0 8rpx 24rpx rgba(235, 47, 150, 0.08);
}

.gacha-banner-left {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.gacha-emoji {
  font-size: 48rpx;
}

.gacha-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: #1a1a1a;
}

.gacha-sub {
  display: block;
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #999;
}

.gacha-cta {
  font-size: 24rpx;
  font-weight: 600;
  color: #eb2f96;
  white-space: nowrap;
}

.product-grid {
  display: flex;
  flex-wrap: wrap;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.product-card-wrap {
  width: 48%;
  margin-bottom: 20rpx;
  padding: 2rpx;
  border-radius: 22rpx;
  background: linear-gradient(135deg, #f0f0f0, #fff);
  box-sizing: border-box;
}

.product-card {
  background: #fff;
  border-radius: 20rpx;
  overflow: hidden;
}

.product-img {
  width: 100%;
  height: 280rpx;
  background: #f5f5f5;
}

.product-info {
  padding: 16rpx 18rpx 20rpx;
}

.product-title {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  color: #262626;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-bottom: 8rpx;
}

.artisan-scroll {
  white-space: nowrap;
  margin-bottom: 24rpx;
}

.artisan-card {
  display: inline-block;
  width: 188rpx;
  text-align: center;
  margin-right: 20rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 24rpx 16rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 8rpx 24rpx rgba(235, 47, 150, 0.06);
  vertical-align: top;
}

.artisan-avatar {
  border-radius: 50%;
  border: 4rpx solid #fff0f6;
}

.avatar-placeholder {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: linear-gradient(135deg, #fff0f6, #f9f0ff);
  color: #eb2f96;
  font-size: 40rpx;
  font-weight: 700;
  border: 4rpx solid #fff;
}

.artisan-name {
  display: block;
  font-size: 26rpx;
  font-weight: 600;
  margin-top: 12rpx;
  color: #262626;
}
