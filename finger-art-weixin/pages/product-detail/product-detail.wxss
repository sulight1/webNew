.banner {
  height: 560rpx;
  border-radius: 16rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
}

.banner-img {
  width: 100%;
  height: 100%;
}

.title {
  font-size: 36rpx;
  font-weight: 600;
  display: block;
}

.price {
  font-size: 40rpx;
  margin: 12rpx 0;
  display: block;
}

.tags {
  gap: 12rpx;
  margin-bottom: 16rpx;
}

.creator {
  padding: 16rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
}

.mini-btn {
  padding: 8rpx 20rpx !important;
  font-size: 22rpx !important;
  line-height: 1.4;
}

.desc {
  color: #666;
  line-height: 1.6;
}

.similar-scroll {
  white-space: nowrap;
  margin-bottom: 120rpx;
}

.similar-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 16rpx;
}

.similar-item image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: #fff;
  padding: 16rpx 24rpx;
  border-top: 1rpx solid #eee;
  gap: 20rpx;
}

.like-btn {
  padding: 16rpx 24rpx;
}

.like-btn.liked {
  color: #eb2f96;
}

.buy-btn {
  flex: 1;
}
