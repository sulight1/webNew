.login-page {
  padding-top: 60rpx;
}

.login-card-wrap {
  padding: 2rpx;
  border-radius: 26rpx;
  background: linear-gradient(135deg, #eb2f96, #722ed1);
  box-shadow: 0 16rpx 48rpx rgba(235, 47, 150, 0.2);
}

.login-card-inner {
  background: #fff;
  border-radius: 24rpx;
  padding: 48rpx 32rpx 40rpx;
}

.login-brand {
  text-align: center;
  margin-bottom: 40rpx;
}

.login-logo {
  display: block;
  font-size: 44rpx;
  font-weight: 800;
  color: #1a1a1a;
}

.login-logo-sub {
  display: block;
  font-size: 22rpx;
  color: #8c8c8c;
  margin-top: 8rpx;
  letter-spacing: 4rpx;
}

.title {
  font-size: 34rpx;
  font-weight: 700;
  margin-bottom: 32rpx;
  text-align: center;
  color: #262626;
}

.input {
  background: #fafafa;
  border: 1rpx solid #f0f0f0;
  border-radius: 16rpx;
  padding: 26rpx 28rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

.input:focus {
  border-color: rgba(235, 47, 150, 0.35);
  background: #fffafb;
}

.submit-btn {
  width: 100%;
  margin-top: 12rpx;
}

.switch {
  text-align: center;
  margin-top: 32rpx;
  color: #eb2f96;
  font-size: 26rpx;
  font-weight: 600;
}

.tip {
  margin-top: 24rpx;
  font-size: 24rpx;
  color: #8c8c8c;
  text-align: center;
  line-height: 1.5;
}
