.page-head {
  margin-bottom: 20rpx;
}

.page-title {
  font-size: 34rpx;
  font-weight: 700;
  color: #262626;
}

.head-btn {
  font-size: 24rpx;
  padding: 0 24rpx;
  height: 64rpx;
  line-height: 64rpx;
}

.hub-tabs {
  margin-bottom: 20rpx;
  gap: 16rpx;
}

.hub-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #595959;
  background: #fff;
  border: 1rpx solid #f0f0f0;
}

.hub-tab.active {
  color: #eb2f96;
  border-color: rgba(235, 47, 150, 0.35);
  background: #fff0f6;
  font-weight: 600;
}

.scope-tabs {
  margin-bottom: 20rpx;
  gap: 12rpx;
  flex-wrap: wrap;
}

.scope-tab {
  padding: 10rpx 24rpx;
  border-radius: 999rpx;
  font-size: 24rpx;
  color: #595959;
  background: #fff;
  border: 1rpx solid #f0f0f0;
}

.scope-tab.active {
  color: #eb2f96;
  border-color: rgba(235, 47, 150, 0.35);
  background: #fff0f6;
}

.skill-card,
.exchange-card {
  margin-bottom: 20rpx;
}

.skill-card-main {
  display: flex;
  gap: 20rpx;
}

.cover {
  width: 160rpx;
  height: 160rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.title-row {
  align-items: flex-start;
  gap: 12rpx;
}

.title {
  font-size: 30rpx;
  font-weight: 600;
  color: #262626;
  flex: 1;
}

.meta {
  font-size: 22rpx;
  color: #8c8c8c;
}

.desc {
  font-size: 24rpx;
  color: #595959;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

.hint {
  font-size: 22rpx;
  color: #eb2f96;
}

.hint.rejected {
  color: #ff4d4f;
}

.status-tag.pending {
  background: #fff7e6;
  color: #fa8c16;
}

.status-tag.approved {
  background: #f6ffed;
  color: #52c41a;
}

.status-tag.rejected {
  background: #fff1f0;
  color: #ff4d4f;
}

.actions {
  margin-top: 16rpx;
  justify-content: flex-end;
  gap: 16rpx;
}

.action-btn {
  margin: 0;
  background: #fff0f6;
  color: #eb2f96;
  border: 1rpx solid rgba(235, 47, 150, 0.2);
}

.action-btn.danger {
  background: #fff1f0;
  color: #ff4d4f;
  border-color: rgba(255, 77, 79, 0.2);
}

.exchange-card-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.exchange-partner {
  font-size: 28rpx;
  color: #262626;
  flex: 1;
}

.partner-name {
  color: #eb2f96;
  font-weight: 600;
}

.exchange-status-tag {
  flex-shrink: 0;
}

.exchange-desc {
  display: block;
  font-size: 24rpx;
  color: #595959;
  margin-bottom: 8rpx;
}

.exchange-meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-bottom: 6rpx;
}

.exchange-meta {
  font-size: 22rpx;
  color: #8c8c8c;
}

.exchange-wait-hint {
  display: block;
  font-size: 22rpx;
  color: #eb2f96;
  margin: 8rpx 0;
}

.exchange-reward {
  display: block;
  font-size: 22rpx;
  color: #52c41a;
  margin-bottom: 8rpx;
}

.exchange-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 12rpx;
}

.exchange-action-btn {
  margin: 0;
  font-size: 22rpx;
  background: #fff;
  color: #595959;
  border: 1rpx solid #e8e8e8;
}

.exchange-action-btn.primary {
  background: #eb2f96;
  color: #fff;
  border-color: #eb2f96;
}

.exchange-action-btn.danger {
  color: #ff4d4f;
  border-color: rgba(255, 77, 79, 0.35);
}

.detail-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  z-index: 1000;
  display: flex;
  align-items: flex-end;
}

.detail-panel {
  width: 100%;
  max-height: 88vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 28rpx calc(32rpx + env(safe-area-inset-bottom));
}

.section-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 24rpx;
}

.field {
  margin-bottom: 20rpx;
}

.field-label {
  display: block;
  font-size: 24rpx;
  color: #595959;
  margin-bottom: 8rpx;
}

.field-input,
.field-textarea,
.picker-value {
  width: 100%;
  box-sizing: border-box;
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  font-size: 28rpx;
  background: #fafafa;
}

.field-textarea {
  min-height: 160rpx;
}

.edit-hint {
  display: block;
  font-size: 22rpx;
  color: #8c8c8c;
  margin-bottom: 20rpx;
}

.edit-cancel {
  margin-top: 16rpx;
  width: 100%;
}

.review-stars {
  display: flex;
  gap: 12rpx;
  margin-bottom: 20rpx;
}

.review-star {
  font-size: 48rpx;
  color: #d9d9d9;
}

.review-star.active {
  color: #faad14;
}
