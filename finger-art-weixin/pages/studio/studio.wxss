.hero {
  background: linear-gradient(135deg, #fff0f6, #f9f0ff);
}

.hero-title {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #eb2f96;
}

.hero-sub {
  display: block;
  color: #666;
  margin: 8rpx 0 20rpx;
}

.hero-actions {
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.flex1 {
  flex: 1;
}

.wallet-bar {
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(235, 47, 150, 0.15);
}

.menu-scroll {
  white-space: nowrap;
  margin-bottom: 20rpx;
}

.menu-chip {
  display: inline-block;
  padding: 16rpx 28rpx;
  margin-right: 12rpx;
  background: #fff;
  border-radius: 32rpx;
  font-size: 26rpx;
  color: #666;
}

.menu-chip.active {
  background: #fff0f6;
  color: #eb2f96;
  font-weight: 600;
}

.sub-tabs {
  white-space: nowrap;
  margin-bottom: 16rpx;
}

.sub-tab {
  display: inline-block;
  padding: 12rpx 24rpx;
  margin-right: 8rpx;
  font-size: 24rpx;
  color: #999;
  border-bottom: 4rpx solid transparent;
}

.sub-tab.active {
  color: #eb2f96;
  border-bottom-color: #eb2f96;
  font-weight: 600;
}

.product-row {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.product-row .thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
}

.flex1 {
  flex: 1;
  min-width: 0;
}

.product-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.meta {
  gap: 16rpx;
  margin-top: 8rpx;
}

.product-actions {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.mini {
  flex: 1;
  padding: 8rpx 0 !important;
  font-size: 22rpx !important;
}

.mini.danger {
  color: #ff4d4f;
  border-color: #ff4d4f;
}

.order-item {
  margin-bottom: 16rpx;
}

.order-title {
  font-weight: 600;
  font-size: 28rpx;
}

.order-req {
  display: block;
  margin-top: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.checkin-card {
  background: linear-gradient(135deg, #fff0f6, #fff);
  margin-bottom: 16rpx;
}

.checkin-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
}

.checkin-reward {
  display: block;
  color: #eb2f96;
  font-size: 24rpx;
  margin-top: 4rpx;
}

.task-item {
  margin-bottom: 16rpx;
}

.task-name {
  display: block;
  font-weight: 600;
  margin-bottom: 4rpx;
}

.task-btn {
  width: 100%;
  margin-top: 12rpx;
}

.boost-tip {
  color: #666;
  font-size: 24rpx;
  margin-top: 8rpx;
}

.stat-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.stat-card {
  text-align: center;
  padding: 24rpx 16rpx;
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: #999;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #eb2f96;
  margin-top: 8rpx;
}

.status-row {
  display: grid;
  grid-template-columns: 140rpx 1fr 60rpx;
  gap: 12rpx;
  align-items: center;
  margin-bottom: 12rpx;
  font-size: 24rpx;
}

.status-bar {
  height: 12rpx;
  background: #f0f0f0;
  border-radius: 6rpx;
  overflow: hidden;
}

.status-fill {
  height: 100%;
  background: #eb2f96;
  max-width: 100%;
}

.top-item {
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.apply-card {
  text-align: center;
  padding: 48rpx 32rpx;
}

.apply-icon {
  display: block;
  font-size: 64rpx;
  margin-bottom: 16rpx;
}

.apply-title {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.apply-desc {
  display: block;
  color: #666;
  line-height: 1.6;
  margin-bottom: 24rpx;
}

.apply-list {
  text-align: left;
  margin-bottom: 32rpx;
}

.apply-list text {
  display: block;
  color: #666;
  margin-bottom: 8rpx;
}
