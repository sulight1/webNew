.cart-fab {
  position: fixed;
  right: 32rpx;
  bottom: calc(140rpx + env(safe-area-inset-bottom));
  width: 104rpx;
  height: 104rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #eb2f96, #722ed1);
  box-shadow: 0 12rpx 32rpx rgba(235, 47, 150, 0.35);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.cart-fab-icon {
  font-size: 44rpx;
}

.cart-fab-badge {
  position: absolute;
  top: -4rpx;
  right: -4rpx;
  min-width: 36rpx;
  height: 36rpx;
  padding: 0 8rpx;
  border-radius: 999rpx;
  background: #ff4d4f;
  color: #fff;
  font-size: 20rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  border: 2rpx solid #fff;
}
