<view class="container">
  <view wx:if="{{!user}}" class="card login-card">
    <text class="login-tip">登录后享受完整服务</text>
    <button class="btn-primary" bindtap="goLogin">登录 / 注册</button>
  </view>

  <view wx:else class="card profile-card">
    <view class="flex-row profile-header">
      <image class="avatar-lg" src="{{user.avatar || ''}}" mode="aspectFill" bindtap="chooseAvatar" />
      <view class="profile-info">
        <view class="flex-row name-line">
          <text class="username">{{user.username}}</text>
          <text class="badge" wx:if="{{user.role === 'ARTISAN'}}">认证手作达人</text>
        </view>
        <text class="account-line" wx:if="{{user.account}}">账号 {{user.account}}</text>
        <text class="text-muted">信用 {{user.creditScore || 100}} · 评分 {{user.rating || 5}}</text>
        <text class="profile-link" bindtap="goPublicProfile">公开主页 ›</text>
        <text class="bio" bindtap="editProfile">{{user.bio || '点击编辑简介'}}</text>
      </view>
    </view>
    <view class="balance-row flex-between" data-url="/pages/wallet/wallet" bindtap="onMenuTap">
      <text>造物币余额</text>
      <text class="text-price">¥{{user.zaowuBiBalance || 0}} ›</text>
    </view>
  </view>

  <view class="card address-card" wx:if="{{user}}">
    <view class="section-title">收货地址</view>
    <text class="address-hint">购买成品或卖家发货时将使用此地址</text>
    <view class="field">
      <text class="field-label">收货人</text>
      <input class="field-input" placeholder="收货人姓名" value="{{shippingName}}" bindinput="onShippingNameInput" />
    </view>
    <view class="field">
      <text class="field-label">手机号</text>
      <input class="field-input" type="number" maxlength="11" placeholder="11 位手机号" value="{{shippingPhone}}" bindinput="onShippingPhoneInput" />
    </view>
    <view class="field">
      <text class="field-label">详细地址</text>
      <textarea class="field-textarea" placeholder="省市区 + 街道门牌号" value="{{shippingAddress}}" bindinput="onShippingAddressInput" maxlength="200" />
    </view>
    <button class="btn-primary address-save" loading="{{savingAddress}}" bindtap="saveShippingAddress">保存收货地址</button>
  </view>

  <view class="card menu-list" wx:if="{{user}}">
    <view
      class="menu-item flex-between"
      wx:for="{{menuItems}}"
      wx:key="key"
      data-url="{{item.url}}"
      bindtap="onMenuTap"
    >
      <text>{{item.title}}</text>
      <view class="menu-right flex-row">
        <text wx:if="{{item.key === 'cart' && cartCount > 0}}" class="menu-badge">{{cartCount > 99 ? '99+' : cartCount}}</text>
        <text class="arrow">›</text>
      </view>
    </view>
  </view>

  <button wx:if="{{user}}" class="btn-outline logout-btn" bindtap="logout">退出登录</button>
</view>
