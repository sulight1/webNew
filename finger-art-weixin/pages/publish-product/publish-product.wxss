.cover-upload {
  height: 360rpx;
  background: linear-gradient(135deg, #fffafb, #f9f0ff);
  border: 2rpx dashed rgba(235, 47, 150, 0.35);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 28rpx;
  overflow: hidden;
  color: #eb2f96;
  font-size: 28rpx;
  font-weight: 600;
}

.cover-upload image {
  width: 100%;
  height: 100%;
}

input,
textarea,
.picker {
  background: #fafafa;
  border: 1rpx solid #f0f0f0;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 20rpx;
  font-size: 28rpx;
}

textarea {
  min-height: 160rpx;
  width: 100%;
  box-sizing: border-box;
}

radio-group {
  margin-bottom: 28rpx;
}

radio-group label {
  margin-right: 32rpx;
  font-size: 28rpx;
  color: #595959;
}

.stock-row {
  margin-bottom: 20rpx;
}

.stock-label {
  display: block;
  font-size: 26rpx;
  color: #595959;
  font-weight: 600;
  margin-bottom: 10rpx;
}

.stock-input {
  background: #fafafa;
  border: 1rpx solid #f0f0f0;
  border-radius: 16rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 8rpx;
}

.stock-tip {
  display: block;
  font-size: 22rpx;
  color: #8c8c8c;
}
