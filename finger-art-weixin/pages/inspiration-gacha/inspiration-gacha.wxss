.page {
  min-height: 100vh;
  padding: 24rpx 24rpx 48rpx;
  background: linear-gradient(180deg, #fff5fb 0%, #f9f9f9 45%, #f9f9f9 100%);
  box-sizing: border-box;
}

.hero {
  position: relative;
  padding: 24rpx 8rpx 32rpx;
}

.hero-glow {
  position: absolute;
  top: -40rpx;
  right: -20rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(235, 47, 150, 0.18), transparent 70%);
  pointer-events: none;
}

.hero-tag {
  display: block;
  font-size: 20rpx;
  letter-spacing: 4rpx;
  color: #eb2f96;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.hero-title {
  font-size: 48rpx;
  font-weight: 800;
  color: #1a1a1a;
}

.accent {
  color: #eb2f96;
}

.hero-sub {
  display: block;
  margin-top: 12rpx;
  font-size: 24rpx;
  color: #8c8c8c;
  line-height: 1.5;
}

.status-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 20rpx;
}

.status-chip {
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  color: #666;
  background: rgba(255, 255, 255, 0.85);
  border: 1rpx solid #eee;
}

.status-chip.free {
  color: #eb2f96;
  border-color: #ffd6e7;
  background: #fff0f6;
}

.machine {
  margin: 8rpx 0 28rpx;
}

.machine-top {
  background: linear-gradient(180deg, #ff85c0 0%, #eb2f96 100%);
  border-radius: 28rpx 28rpx 12rpx 12rpx;
  padding: 20rpx;
  box-shadow: 0 16rpx 40rpx rgba(235, 47, 150, 0.25);
}

.machine-window {
  min-height: 420rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-sizing: border-box;
  overflow: hidden;
}

.machine-window.spinning {
  animation: pulse 0.8s ease-in-out infinite alternate;
}

@keyframes pulse {
  from { transform: scale(1); }
  to { transform: scale(1.01); }
}

.machine-placeholder,
.machine-spin {
  height: 360rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
  font-size: 26rpx;
}

.machine-emoji,
.spin-emoji {
  font-size: 72rpx;
  margin-bottom: 16rpx;
}

.spin-text {
  color: #eb2f96;
  font-weight: 600;
}

.result-card {
  animation: reveal 0.45s ease;
}

@keyframes reveal {
  from { opacity: 0; transform: translateY(16rpx); }
  to { opacity: 1; transform: translateY(0); }
}

.result-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.tag {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
}

.tag.style {
  background: #fff0f6;
  color: #eb2f96;
}

.tag.craft {
  background: #f9f0ff;
  color: #722ed1;
}

.palette-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-bottom: 18rpx;
}

.palette-dot {
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  border: 2rpx solid rgba(0, 0, 0, 0.06);
}

.palette-name {
  font-size: 24rpx;
  color: #666;
}

.result-copy {
  display: block;
  font-size: 30rpx;
  line-height: 1.6;
  color: #333;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.result-title {
  display: block;
  font-size: 24rpx;
  color: #999;
  margin-bottom: 16rpx;
}

.result-image {
  width: 100%;
  height: 320rpx;
  border-radius: 16rpx;
  background: #f5f5f5;
}

.machine-base {
  height: 24rpx;
  margin: 0 40rpx;
  background: #c41d7f;
  border-radius: 0 0 16rpx 16rpx;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.btn-draw {
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 600;
}

.btn-draw.primary {
  background: linear-gradient(90deg, #eb2f96, #ff85c0);
  color: #fff;
  border: none;
}

.btn-draw.outline {
  background: #fff;
  color: #eb2f96;
  border: 2rpx solid #ffd6e7;
}

.result-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.mini-btn {
  flex: 1 1 calc(50% - 12rpx);
  min-width: calc(50% - 12rpx);
  margin: 0;
  font-size: 24rpx;
  background: #fff;
  color: #eb2f96;
  border: 1rpx solid #ffd6e7;
  border-radius: 16rpx;
}

.mini-btn.ghost {
  color: #666;
  border-color: #eee;
}

.tips {
  margin-top: 28rpx;
  padding: 20rpx;
  background: rgba(255, 255, 255, 0.7);
  border-radius: 16rpx;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.tips text {
  font-size: 22rpx;
  color: #999;
  line-height: 1.5;
}
