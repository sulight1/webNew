.cover-upload {
  height: 300rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.cover-upload image {
  width: 100%;
  height: 100%;
}

input, textarea, .picker {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

textarea {
  min-height: 160rpx;
  width: 100%;
  box-sizing: border-box;
}
