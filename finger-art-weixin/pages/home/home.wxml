<view class="container">
  <view class="home-hero">
    <view class="home-hero-mesh">
      <view class="mesh-blob mesh-pink"></view>
      <view class="mesh-blob mesh-purple"></view>
    </view>
    <view class="home-hero-body">
      <text class="home-eyebrow">FINGER ART</text>
      <view class="home-title">指尖<text class="gradient-text">造物</text></view>
      <text class="home-sub">发现手作之美，连接匠人与爱好者</text>
      <view class="hero-stats flex-row">
        <view class="stat-item">
          <text class="stat-num">{{stats.productCount || 0}}</text>
          <text class="stat-label">作品</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">{{stats.artisanCount || 0}}</text>
          <text class="stat-label">匠人</text>
        </view>
        <view class="stat-divider"></view>
        <view class="stat-item">
          <text class="stat-num">{{stats.orderCount || 0}}</text>
          <text class="stat-label">开放需求</text>
        </view>
      </view>
      <view class="hero-actions flex-row">
        <button class="btn-primary" bindtap="goMarketplace">逛市集</button>
        <button class="btn-outline btn-glass" bindtap="goCustomRequest">发布需求</button>
      </view>
    </view>
  </view>

  <view class="gacha-banner" bindtap="goInspirationGacha">
    <view class="gacha-banner-left">
      <text class="gacha-emoji">🎰</text>
      <view>
        <text class="gacha-title">今日灵感扭蛋</text>
        <text class="gacha-sub">随机风格 · 工艺 · 配色 · AI 参考图</text>
      </view>
    </view>
    <view class="gacha-cta">免费开扭 ›</view>
  </view>

  <view class="section-head">
    <text class="section-subtitle">HOT PICKS</text>
    <view class="section-title-row">
      <text class="section-title">热门作品</text>
      <view class="section-line"></view>
    </view>
  </view>
  <view wx:if="{{loading}}" class="empty">加载中...</view>
  <view wx:elif="{{hotProducts.length === 0}}" class="empty-guide">
    <text class="empty-guide-title">暂无作品</text>
  </view>
  <view class="product-grid" wx:else>
    <view
      class="product-card-wrap"
      wx:for="{{hotProducts}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goProduct"
    >
      <view class="product-card">
        <image class="product-img" src="{{item.image}}" mode="aspectFill" />
        <view class="product-info">
          <text class="product-title">{{item.title}}</text>
          <text class="text-price">¥{{item.price}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="section-head">
    <text class="section-subtitle">ARTISANS</text>
    <view class="section-title-row">
      <text class="section-title">优秀匠人</text>
      <view class="section-line"></view>
    </view>
  </view>
  <scroll-view scroll-x class="artisan-scroll" enhanced show-scrollbar="{{false}}">
    <view
      class="artisan-card"
      wx:for="{{artisans}}"
      wx:key="id"
      data-id="{{item.id}}"
      bindtap="goArtisan"
    >
      <image class="avatar-lg artisan-avatar" src="{{item.avatar}}" mode="aspectFill" wx:if="{{item.avatar}}" />
      <view class="avatar-lg avatar-placeholder" wx:else>{{item.username[0] || '匠'}}</view>
      <text class="artisan-name">{{item.username}}</text>
      <text class="text-muted">信用 {{item.creditScore || 100}}</text>
    </view>
  </scroll-view>
</view>
