.cover-upload {
  height: 360rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.cover-upload image {
  width: 100%;
  height: 100%;
}

input, textarea, .picker {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
}

textarea {
  min-height: 120rpx;
  width: 100%;
  box-sizing: border-box;
}

radio-group {
  margin-bottom: 24rpx;
}

radio-group label {
  margin-right: 32rpx;
}

.stock-row {
  margin-bottom: 16rpx;
}

.stock-label {
  display: block;
  font-size: 26rpx;
  color: #333;
  margin-bottom: 8rpx;
}

.stock-input {
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 8rpx;
}

.stock-tip {
  display: block;
  font-size: 22rpx;
  color: #999;
}
