.tabs {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  color: #666;
}

.tab.active {
  color: #eb2f96;
  font-weight: 600;
  border-bottom: 4rpx solid #eb2f96;
}

.publish-btn {
  width: 100%;
  margin-bottom: 24rpx;
}

.req-title {
  font-size: 30rpx;
  font-weight: 600;
}

.meta {
  margin: 16rpx 0;
}

.actions {
  gap: 16rpx;
  margin-top: 12rpx;
}

.action-btn {
  flex: 1;
  font-size: 24rpx !important;
}
