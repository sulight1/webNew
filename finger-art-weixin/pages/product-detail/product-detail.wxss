.banner {
  height: 560rpx;
  border-radius: 20rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 12rpx 40rpx rgba(0, 0, 0, 0.08);
}

.banner-img {
  width: 100%;
  height: 100%;
}

.info-card {
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
  box-shadow: 0 8rpx 32rpx rgba(235, 47, 150, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 800;
  display: block;
  color: #1a1a1a;
  line-height: 1.35;
}

.price {
  font-size: 44rpx;
  font-weight: 800;
  margin: 16rpx 0;
  display: block;
  color: #eb2f96;
}

.tags {
  gap: 12rpx;
  margin-bottom: 16rpx;
  flex-wrap: wrap;
}

.stock-tag {
  background: #f5f5f5;
  color: #8c8c8c;
}

.stock-tag.warn {
  background: #fff7e6;
  color: #fa8c16;
}

.qty-row {
  margin: 16rpx 0 8rpx;
}

.qty-label {
  font-size: 28rpx;
  color: #595959;
}

.qty-stepper {
  gap: 0;
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
}

.qty-btn {
  width: 64rpx;
  height: 64rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  font-size: 36rpx;
  color: #595959;
}

.qty-num {
  min-width: 72rpx;
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
}

.line-total {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #eb2f96;
  margin-bottom: 16rpx;
}

.creator {
  padding: 20rpx 0;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
  margin-bottom: 16rpx;
  align-items: center;
}

.creator-main {
  display: flex;
  align-items: center;
  gap: 16rpx;
  flex: 1;
  min-width: 0;
}

.creator-avatar {
  width: 72rpx;
  height: 72rpx;
  border-radius: 50%;
  flex-shrink: 0;
  background: #f5f5f5;
}

.creator-text {
  display: flex;
  flex-direction: column;
  min-width: 0;
}

.creator-name {
  font-size: 28rpx;
  font-weight: 700;
  color: #262626;
}

.creator-hint {
  margin-top: 4rpx;
  font-size: 22rpx;
  color: #8c8c8c;
}

.creator-avatar-placeholder {
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  font-weight: 700;
  color: #eb2f96;
  background: #fff0f6;
}

.from-order-banner {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 20rpx;
  margin-bottom: 16rpx;
  border-radius: 12rpx;
  background: #fff7fb;
  border: 1rpx solid #ffd6e7;
  font-size: 24rpx;
  color: #595959;
}

.from-order-link {
  color: #eb2f96;
  font-weight: 600;
  flex-shrink: 0;
}

.mini-btn {
  padding: 10rpx 24rpx !important;
  font-size: 22rpx !important;
  line-height: 1.4;
  border-radius: 999rpx !important;
}

.desc {
  color: #595959;
  line-height: 1.7;
  font-size: 28rpx;
}

.similar-head {
  margin: 32rpx 0 20rpx;
}

.similar-scroll {
  white-space: nowrap;
  margin-bottom: calc(128rpx + env(safe-area-inset-bottom));
}

.similar-item {
  display: inline-block;
  width: 200rpx;
  margin-right: 16rpx;
}

.similar-item image {
  width: 200rpx;
  height: 200rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 12rpx;
  background: rgba(255, 255, 255, 0.98);
  backdrop-filter: blur(16px);
  padding: 12rpx 20rpx calc(12rpx + env(safe-area-inset-bottom));
  border-top: 1rpx solid rgba(235, 47, 150, 0.08);
  box-shadow: 0 -4rpx 24rpx rgba(0, 0, 0, 0.04);
  box-sizing: border-box;
}

.bottom-icons {
  display: flex;
  flex-shrink: 1;
  gap: 0;
  padding-right: 4rpx;
  border-right: 1rpx solid #f0f0f0;
}

.icon-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  width: 56rpx;
  padding: 0;
  color: #8c8c8c;
}

.icon-action-symbol {
  font-size: 30rpx;
  line-height: 1.15;
}

.contact-symbol {
  font-size: 28rpx;
}

.icon-action-label {
  margin-top: 2rpx;
  font-size: 16rpx;
  line-height: 1.2;
}

.icon-action.liked {
  color: #eb2f96;
}

.icon-action.favorited {
  color: #faad14;
}

.share-action {
  width: 56rpx !important;
  min-width: 56rpx !important;
  max-width: 56rpx !important;
  margin: 0 !important;
  padding: 0 !important;
  background: transparent !important;
  border: none !important;
  line-height: normal !important;
  font-weight: normal !important;
  border-radius: 0 !important;
}

.share-action::after {
  border: none;
}

.share-symbol {
  font-size: 28rpx;
  font-weight: 600;
}

.bottom-actions {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 12rpx;
  min-width: 320rpx;
}

.cart-add-btn,
.buy-btn {
  margin: 0 !important;
  box-sizing: border-box;
  white-space: nowrap;
}

.cart-add-btn {
  flex: 1;
  min-width: 140rpx;
  height: 76rpx !important;
  line-height: 76rpx !important;
  padding: 0 20rpx !important;
  font-size: 28rpx !important;
  font-weight: 500 !important;
  border-radius: 38rpx !important;
  border-width: 1rpx !important;
  box-shadow: none !important;
}

.cart-add-btn::after,
.buy-btn::after {
  border: none;
}

.buy-btn {
  flex: 1.2;
  min-width: 160rpx;
  height: 80rpx !important;
  line-height: 80rpx !important;
  padding: 0 24rpx !important;
  font-size: 30rpx !important;
  font-weight: 600 !important;
  border-radius: 40rpx !important;
  box-shadow: 0 6rpx 20rpx rgba(235, 47, 150, 0.22) !important;
}

.custom-mask {
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.45);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 100;
}

.custom-panel {
  width: 86%;
  background: #fff;
  border-radius: 16rpx;
  padding: 32rpx 28rpx;
  box-sizing: border-box;
}

.custom-panel-title {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #262626;
  margin-bottom: 12rpx;
}

.custom-panel-hint {
  display: block;
  font-size: 24rpx;
  color: #8c8c8c;
  line-height: 1.6;
  margin-bottom: 20rpx;
}

.custom-textarea {
  width: 100%;
  min-height: 220rpx;
  border: 1rpx solid #e8e8e8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  box-sizing: border-box;
  font-size: 28rpx;
  line-height: 1.6;
}

.custom-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 24rpx;
}

.custom-actions button {
  flex: 1;
  margin-bottom: 0;
}
