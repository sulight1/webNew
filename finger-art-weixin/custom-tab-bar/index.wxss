.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 108rpx;
  background: rgba(255, 255, 255, 0.92);
  backdrop-filter: blur(20px);
  display: flex;
  border-top: 1rpx solid rgba(235, 47, 150, 0.1);
  box-shadow: 0 -8rpx 32rpx rgba(235, 47, 150, 0.08);
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #8c8c8c;
  transition: color 0.2s;
}

.tab-item.active {
  color: #eb2f96;
}

.tab-item.active .tab-icon {
  transform: scale(1.08);
}

.tab-icon {
  font-size: 38rpx;
  line-height: 1.2;
  transition: transform 0.2s;
}

.tab-text {
  font-size: 20rpx;
  margin-top: 4rpx;
  font-weight: 500;
}

.tab-item.active .tab-text {
  font-weight: 700;
}
