.product-row {
  gap: 20rpx;
  margin-top: 16rpx;
}

.product-thumb {
  width: 160rpx;
  height: 160rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.product-info {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.product-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #262626;
}

.ship-name {
  display: block;
  font-weight: 600;
  margin-bottom: 8rpx;
}

.ship-address {
  display: block;
  color: #595959;
  font-size: 26rpx;
  line-height: 1.6;
}

.empty-tip {
  color: #faad14;
  font-size: 26rpx;
}

.edit-link {
  display: block;
  margin-top: 16rpx;
  color: #eb2f96;
  font-size: 26rpx;
}

.pay-option {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  border: 2rpx solid #f0f0f0;
  border-radius: 16rpx;
  margin-top: 16rpx;
}

.pay-option.active {
  border-color: #eb2f96;
  background: #fff5fb;
}

.pay-icon {
  width: 72rpx;
  height: 72rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-weight: 800;
  font-size: 28rpx;
}

.pay-icon.coin {
  background: linear-gradient(135deg, #eb2f96, #722ed1);
}

.pay-main {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.pay-label {
  font-size: 30rpx;
  font-weight: 700;
}

.pay-desc {
  font-size: 22rpx;
  color: #8c8c8c;
}

.pay-check {
  color: #eb2f96;
  font-weight: 700;
  font-size: 32rpx;
}

.summary-row {
  margin-bottom: 20rpx;
}

.total {
  font-size: 40rpx;
}

.pay-btn {
  width: 100%;
}
