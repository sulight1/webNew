.chat-page {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f7f7f8;
}

.chat-scroll {
  flex: 1;
  padding: 24rpx;
  box-sizing: border-box;
}

.chat-empty {
  text-align: center;
  color: #8c8c8c;
  font-size: 26rpx;
  padding: 80rpx 0;
}

.msg-row {
  display: flex;
  flex-direction: column;
  margin-bottom: 24rpx;
  max-width: 78%;
}

.msg-row.peer {
  align-items: flex-start;
}

.msg-row.mine {
  align-items: flex-end;
  margin-left: auto;
}

.msg-bubble {
  padding: 16rpx 22rpx;
  border-radius: 20rpx;
  font-size: 28rpx;
  line-height: 1.5;
  word-break: break-all;
}

.msg-row.peer .msg-bubble {
  background: #fff;
  color: #262626;
  border: 1rpx solid rgba(0, 0, 0, 0.06);
}

.msg-row.mine .msg-bubble {
  background: linear-gradient(135deg, #eb2f96, #722ed1);
  color: #fff;
}

.msg-time {
  margin-top: 8rpx;
  font-size: 20rpx;
  color: #bfbfbf;
}

.chat-input-bar {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 12rpx 20rpx calc(12rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #f0f0f0;
  box-sizing: border-box;
}

.chat-input {
  flex: 1;
  height: 68rpx;
  padding: 0 24rpx;
  background: #f5f5f5;
  border-radius: 34rpx;
  font-size: 28rpx;
}

.chat-send-btn {
  margin: 0 !important;
  height: 68rpx !important;
  line-height: 68rpx !important;
  padding: 0 28rpx !important;
  font-size: 26rpx !important;
  border-radius: 34rpx !important;
  background: linear-gradient(135deg, #eb2f96, #722ed1) !important;
  color: #fff !important;
  border: none !important;
}

.chat-send-btn::after {
  border: none;
}

.chat-send-btn[disabled] {
  opacity: 0.45;
}
