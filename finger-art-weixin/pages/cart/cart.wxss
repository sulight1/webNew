.page-head {
  margin-bottom: 24rpx;
}

.page-title {
  display: block;
  font-size: 40rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.clear-btn {
  color: #ff4d4f;
  font-size: 26rpx;
}

.cart-item {
  display: flex;
  gap: 20rpx;
}

.cart-thumb {
  width: 180rpx;
  height: 180rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
  background: #f5f5f5;
}

.cart-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.cart-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #262626;
}

.cart-actions {
  margin-top: 8rpx;
}

.qty-stepper {
  gap: 0;
  border: 1rpx solid #f0f0f0;
  border-radius: 12rpx;
  overflow: hidden;
}

.qty-btn {
  width: 56rpx;
  height: 56rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fafafa;
  font-size: 32rpx;
  color: #595959;
}

.qty-num {
  min-width: 64rpx;
  text-align: center;
  font-size: 28rpx;
  font-weight: 600;
}

.cart-btns {
  gap: 12rpx;
  margin-top: 12rpx;
}

.mini {
  flex: 1;
  font-size: 24rpx !important;
  padding: 12rpx 0 !important;
  line-height: 1.4;
}

.checkout-btn {
  flex: 1.2;
}

.cart-footer {
  margin-top: 8rpx;
}

.footer-total {
  font-size: 40rpx;
}

.empty-guide {
  text-align: center;
  padding: 120rpx 32rpx;
}

.empty-guide-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.empty-btn {
  margin-top: 32rpx;
  width: 280rpx;
}
