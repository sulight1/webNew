<view class="container">
  <view class="tabs flex-row">
    <view class="tab {{tab === 'buyer' ? 'active' : ''}}" data-tab="buyer" bindtap="onTabChange">我买到的</view>
    <view class="tab {{tab === 'seller' ? 'active' : ''}}" data-tab="seller" bindtap="onTabChange">我卖出的</view>
  </view>

  <view wx:if="{{loading}}" class="empty">加载中...</view>
  <view wx:elif="{{orders.length === 0}}" class="empty">暂无订单</view>
  <view class="card order-item" wx:for="{{orders}}" wx:key="id" data-id="{{item.id}}" bindtap="goDetail">
    <view class="flex-between">
      <text>订单 #{{item.id}}</text>
      <text class="tag">{{item.statusLabel}}</text>
    </view>
    <text
      wx:if="{{item.productId}}"
      class="order-title-link"
      catchtap="goProduct"
      data-product-id="{{item.productId}}"
      data-order-id="{{item.id}}"
    >{{item.productTitle || '定制订单'}} ›</text>
    <text wx:else class="text-muted">{{item.productTitle || '定制订单'}}</text>
    <text class="order-hint text-muted" wx:if="{{item.productId}}">点击标题看作品，点击卡片看订单进度</text>
    <text class="order-req text-muted" wx:if="{{item.requirements}}">{{item.requirements}}</text>
    <view class="flex-between">
      <text class="text-price">¥{{item.price}}<text wx:if="{{item.quantity > 1}}" class="qty-text"> × {{item.quantity}}</text></text>
      <text class="text-muted">{{item.createTime}}</text>
    </view>
  </view>
</view>
