page {
  background: #f5f5f5;
  color: #333;
  font-size: 28rpx;
  box-sizing: border-box;
}

.container {
  padding: 24rpx;
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

.card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.04);
}

.section-title {
  font-size: 32rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
  color: #1a1a1a;
}

.btn-primary {
  background: linear-gradient(135deg, #eb2f96, #722ed1);
  color: #fff;
  border: none;
  border-radius: 44rpx;
  font-size: 28rpx;
  padding: 16rpx 32rpx;
}

.btn-primary::after {
  border: none;
}

.btn-outline {
  background: #fff;
  color: #eb2f96;
  border: 2rpx solid #eb2f96;
  border-radius: 44rpx;
  font-size: 28rpx;
  padding: 14rpx 32rpx;
}

.btn-outline::after {
  border: none;
}

.text-muted {
  color: #999;
  font-size: 24rpx;
}

.text-price {
  color: #eb2f96;
  font-weight: 600;
}

.tag {
  display: inline-block;
  padding: 4rpx 12rpx;
  font-size: 22rpx;
  border-radius: 8rpx;
  background: #fff0f6;
  color: #eb2f96;
}

.empty {
  text-align: center;
  padding: 80rpx 0;
  color: #999;
}

.flex-row {
  display: flex;
  align-items: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: #f0f0f0;
}

.avatar-lg {
  width: 120rpx;
  height: 120rpx;
}

.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}
