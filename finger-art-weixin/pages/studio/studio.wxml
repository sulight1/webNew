<!-- 非手作达人：申请入口 -->
<view class="container" wx:if="{{!isArtisan}}">
  <view class="card apply-card" wx:if="{{isPending}}">
    <text class="apply-icon">⏳</text>
    <text class="apply-title">申请审核中</text>
    <text class="apply-desc">平台将在 1-3 个工作日内完成审核，请留意通知中心</text>
  </view>
  <view class="card apply-card" wx:else>
    <text class="apply-icon">✨</text>
    <text class="apply-title">成为手作达人</text>
    <text class="apply-desc">提交申请后由平台审核，通过即可发布作品、接收订单并查看经营数据。</text>
    <view class="apply-list">
      <text>· 发布与管理手工作品</text>
      <text>· 处理店铺订单与私信咨询</text>
      <text>· 造物币任务与经营数据分析</text>
    </view>
    <button class="btn-primary" loading="{{applying}}" bindtap="applyArtisan">提交手作达人申请</button>
  </view>
</view>

<!-- 手作达人工作台 -->
<view class="container" wx:else>
  <view class="hero card">
    <text class="hero-title">手作达人工作台</text>
    <text class="hero-sub">在这里管理你的每一件匠心之作</text>
    <view class="hero-actions flex-row">
      <button class="btn-primary flex1" bindtap="goPublish">发布新作品</button>
      <button class="btn-outline flex1" bindtap="goProfile">公开主页</button>
    </view>
    <view class="wallet-bar flex-between">
      <text>造物币余额</text>
      <text class="text-price">¥{{user.zaowuBiBalance || 0}}</text>
    </view>
  </view>

  <scroll-view scroll-x class="menu-scroll">
    <view
      wx:for="{{menus}}"
      wx:key="key"
      class="menu-chip {{menu === item.key ? 'active' : ''}}"
      data-menu="{{item.key}}"
      bindtap="onMenuChange"
    >{{item.title}}</view>
  </scroll-view>

  <view wx:if="{{loading}}" class="empty">加载中...</view>

  <!-- 我的作品库 -->
  <block wx:elif="{{menu === 'my-products'}}">
    <scroll-view scroll-x class="sub-tabs">
      <view
        wx:for="{{productTabs}}"
        wx:key="key"
        class="sub-tab {{productTab === item.key ? 'active' : ''}}"
        data-tab="{{item.key}}"
        bindtap="onProductTabChange"
      >{{item.label}}</view>
    </scroll-view>
    <view wx:if="{{filteredProducts.length === 0}}" class="empty">暂无作品，快去发布吧</view>
    <view class="card product-row" wx:for="{{filteredProducts}}" wx:key="id">
      <image class="thumb" src="{{item.image}}" mode="aspectFill" />
      <view class="info flex1">
        <text class="product-title">{{item.title}}</text>
        <text class="tag">{{item.statusLabel}}</text>
        <view class="meta flex-row">
          <text class="text-price">¥{{item.price}}</text>
          <text class="text-muted" wx:if="{{item.isReadyMade}}">库存 {{item.stock || 1}}</text>
          <text class="text-muted">❤ {{item.likes || 0}}</text>
        </view>
        <view class="product-actions">
          <button class="btn-outline mini" data-id="{{item.id}}" catchtap="boostProduct">推广</button>
          <button class="btn-outline mini" data-id="{{item.id}}" catchtap="editProduct">改价</button>
          <button class="btn-outline mini danger" data-id="{{item.id}}" catchtap="deleteProduct">删除</button>
        </view>
      </view>
    </view>
  </block>

  <!-- 店铺订单 -->
  <block wx:elif="{{menu === 'orders'}}">
    <scroll-view scroll-x class="sub-tabs">
      <view
        wx:for="{{orderTabs}}"
        wx:key="key"
        class="sub-tab {{orderTab === item.key ? 'active' : ''}}"
        data-tab="{{item.key}}"
        bindtap="onOrderTabChange"
      >{{item.label}}</view>
    </scroll-view>
    <view wx:if="{{filteredOrders.length === 0}}" class="empty">暂无店铺订单</view>
    <view class="card order-item" wx:for="{{filteredOrders}}" wx:key="id" data-id="{{item.id}}" bindtap="goOrder">
      <view class="flex-between">
        <text class="order-title">{{item.productTitle}}</text>
        <text class="tag">{{item.statusLabel}}</text>
      </view>
      <view class="flex-between">
        <text class="text-muted">{{item.typeLabel}} · 买家 {{item.buyerName}}</text>
        <text class="text-price">¥{{item.price}}</text>
      </view>
      <text class="text-muted order-req" wx:if="{{item.requirements}}">{{item.requirements}}</text>
    </view>
  </block>

  <!-- 任务与签到 -->
  <block wx:elif="{{menu === 'coin-tasks'}}">
    <view class="card checkin-card flex-between">
      <view>
        <text class="checkin-title">每日签到</text>
        <text class="checkin-reward">+5 造物币</text>
      </view>
      <button class="btn-primary" loading="{{checkingIn}}" bindtap="doCheckIn">立即签到</button>
    </view>
    <view wx:if="{{tasks.length === 0}}" class="empty">暂无任务</view>
    <view class="card task-item" wx:for="{{tasks}}" wx:key="code">
      <view class="flex-between">
        <view>
          <text class="task-name">{{item.name}}</text>
          <text class="text-muted">{{item.description}}</text>
        </view>
        <text class="text-price">+{{item.coins}}</text>
      </view>
      <button
        class="btn-outline task-btn"
        data-code="{{item.code}}"
        disabled="{{item.claimed}}"
        loading="{{claiming === item.code}}"
        bindtap="claimTask"
      >{{item.claimed ? '已领取' : '领取'}}</button>
    </view>
    <view class="boost-tip card">花费 20 造物币，作品获得 7 天优先曝光（在「我的作品库」操作）</view>
  </block>

  <!-- 经营数据 -->
  <block wx:elif="{{menu === 'analytics'}}">
    <view wx:if="{{!analytics}}" class="empty">暂无数据</view>
    <block wx:else>
      <view class="stat-grid">
        <view class="stat-card card" wx:for="{{statCards}}" wx:key="label">
          <text class="stat-label">{{item.label}}</text>
          <text class="stat-value">{{item.value}}</text>
        </view>
      </view>
      <view class="card">
        <view class="section-title">订单状态分布</view>
        <view wx:if="{{analytics.orderStatusList.length === 0}}" class="text-muted">暂无订单</view>
        <view class="status-row" wx:for="{{analytics.orderStatusList}}" wx:key="key">
          <text class="status-label">{{item.label}}</text>
          <view class="status-bar"><view class="status-fill" style="width: {{item.percent}}%;"></view></view>
          <text>{{item.count}}</text>
        </view>
      </view>
      <view class="card">
        <view class="section-title">人气作品 Top5</view>
        <view wx:if="{{!analytics.topProducts || analytics.topProducts.length === 0}}" class="text-muted">暂无作品</view>
        <view class="top-item flex-between" wx:for="{{analytics.topProducts}}" wx:key="id">
          <text>{{item.title}}</text>
          <text class="text-muted">❤ {{item.likes}}<text wx:if="{{item.exposureBoost}}" class="tag">推广中</text></text>
        </view>
      </view>
    </block>
  </block>
</view>
