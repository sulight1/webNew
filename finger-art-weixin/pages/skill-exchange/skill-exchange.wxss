.form-card input,
.form-card textarea {
  width: 100%;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  box-sizing: border-box;
}

.exchange-item {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #f0f0f0;
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}
