.tab-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  border-top: 1rpx solid #eee;
  z-index: 999;
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #999;
}

.tab-item.active {
  color: #eb2f96;
}

.tab-icon {
  font-size: 36rpx;
  line-height: 1.2;
}

.tab-text {
  font-size: 20rpx;
  margin-top: 4rpx;
}
