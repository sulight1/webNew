.scope-tabs {
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 20rpx;
  overflow: hidden;
}

.scope-tab {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  color: #666;
  font-size: 28rpx;
}

.scope-tab.active {
  color: #eb2f96;
  font-weight: 600;
  border-bottom: 4rpx solid #eb2f96;
}

.feed-cover-status.open {
  background: rgba(235, 47, 150, 0.9);
}

.feed-cover-status.matched {
  background: rgba(82, 196, 26, 0.9);
}

.feed-cover-status.ended {
  background: rgba(0, 0, 0, 0.45);
}
