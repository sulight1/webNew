<view class="container" wx:if="{{product}}">
  <swiper class="banner" indicator-dots autoplay circular>
    <swiper-item>
      <image class="banner-img" src="{{product.image}}" mode="aspectFill" />
    </swiper-item>
    <swiper-item wx:for="{{product.detailImagesList}}" wx:key="*this">
      <image class="banner-img" src="{{item}}" mode="aspectFill" />
    </swiper-item>
  </swiper>

  <view class="info-card">
    <text class="title">{{product.title}}</text>
    <text class="text-price price">¥{{product.price}}</text>
    <view class="tags flex-row">
      <text class="tag">{{product.type === 'READY_MADE' ? '成品' : '可定制'}}</text>
      <text class="tag" wx:if="{{product.categoryLabel}}">{{product.categoryLabel}}</text>
      <text class="tag stock-tag" wx:if="{{isSoldOut}}">已售罄</text>
      <text class="tag stock-tag warn" wx:elif="{{product.type !== 'CUSTOMIZABLE' && product.stock <= 3}}">仅剩 {{product.stock}} 件</text>
    </view>
    <view class="qty-row flex-between" wx:if="{{product.type !== 'CUSTOMIZABLE' && !isSoldOut}}">
      <text class="qty-label">购买数量</text>
      <view class="qty-stepper flex-row">
        <view class="qty-btn" bindtap="onMinusQty">−</view>
        <text class="qty-num">{{purchaseQuantity}}</text>
        <view class="qty-btn" bindtap="onPlusQty">+</view>
      </view>
    </view>
    <text class="line-total" wx:if="{{product.type !== 'CUSTOMIZABLE' && !isSoldOut}}">小计 ¥{{lineTotal}}</text>
    <view wx:if="{{fromOrderId}}" class="from-order-banner" bindtap="goBackToOrder">
      <text>来自订单 #{{fromOrderId}}</text>
      <text class="from-order-link">返回查看交易进度 ›</text>
    </view>
    <view class="creator flex-between">
      <view class="creator-main" bindtap="goArtisan">
        <image wx:if="{{product.creatorAvatar}}" class="creator-avatar" src="{{product.creatorAvatar}}" mode="aspectFill" />
        <view wx:else class="creator-avatar creator-avatar-placeholder">匠</view>
        <view class="creator-text">
          <text class="creator-name">{{product.creator}}</text>
          <text class="creator-hint">点击查看手作人主页</text>
        </view>
      </view>
      <button class="btn-outline mini-btn" catchtap="onFollow">{{isFollowing ? '已关注' : '+ 关注'}}</button>
    </view>
    <text class="desc">{{product.description || '暂无描述'}}</text>
  </view>

  <view class="section-head similar-head">
    <text class="section-subtitle">FOR YOU</text>
    <view class="section-title-row">
      <text class="section-title">猜你喜欢</text>
      <view class="section-line"></view>
    </view>
  </view>
  <scroll-view scroll-x class="similar-scroll">
    <view class="similar-item" wx:for="{{similar}}" wx:key="id" data-id="{{item.id}}" bindtap="goSimilar">
      <image src="{{item.image}}" mode="aspectFill" />
      <text>¥{{item.price}}</text>
    </view>
  </scroll-view>

  <view class="bottom-bar safe-bottom">
    <view class="bottom-icons">
      <view class="icon-action {{isLiked ? 'liked' : ''}}" bindtap="onLike">
        <text class="icon-action-symbol">{{isLiked ? '❤️' : '🤍'}}</text>
        <text class="icon-action-label">{{product.likes || 0}}</text>
      </view>
      <view class="icon-action {{isFavorited ? 'favorited' : ''}}" bindtap="onFavorite">
        <text class="icon-action-symbol">{{isFavorited ? '★' : '☆'}}</text>
        <text class="icon-action-label">收藏</text>
      </view>
      <view class="icon-action" bindtap="onContactCreator">
        <text class="icon-action-symbol contact-symbol">💬</text>
        <text class="icon-action-label">咨询</text>
      </view>
      <button class="icon-action share-action" open-type="share">
        <text class="icon-action-symbol share-symbol">↗</text>
        <text class="icon-action-label">分享</text>
      </button>
    </view>
    <view class="bottom-actions">
      <button wx:if="{{canAddToCart}}" class="btn-outline cart-add-btn" bindtap="onAddToCart">加入购物车</button>
      <button class="btn-primary buy-btn" disabled="{{isSoldOut && product.type !== 'CUSTOMIZABLE'}}" bindtap="onBuy">
        {{isSoldOut && product.type !== 'CUSTOMIZABLE' ? '已售罄' : (product.type === 'CUSTOMIZABLE' ? '发起定制' : '立即购买')}}
      </button>
    </view>
  </view>
</view>
<view wx:elif="{{loading}}" class="empty">加载中...</view>

<view class="custom-mask" wx:if="{{showCustomModal}}" bindtap="closeCustomModal">
  <view class="custom-panel" catchtap="stopPropagation">
    <view class="custom-panel-title">填写定制需求</view>
    <text class="custom-panel-hint">向 {{product.creator}} 说明尺寸、颜色、材质等细节，手作人确认后再支付定金。</text>
    <textarea
      class="custom-textarea"
      placeholder="请描述你的定制需求..."
      maxlength="500"
      value="{{customRequirements}}"
      bindinput="onCustomRequirementsInput"
    />
    <view class="custom-actions">
      <button class="btn-outline" bindtap="closeCustomModal">取消</button>
      <button class="btn-primary" loading="{{customSubmitting}}" bindtap="submitCustomOrder">提交定制请求</button>
    </view>
  </view>
</view>
